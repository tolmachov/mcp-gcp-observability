# ===========================================
# Required: GCP Project Configuration
# ===========================================
GCP_DEFAULT_PROJECT=spring-monolith-431606-v7

# ===========================================
# Optional: Limits
# ===========================================

# Maximum number of log entries per request (default: 1000)
LOGS_MAX_LIMIT=1000

# Maximum number of error groups per request (default: 100)
ERRORS_MAX_LIMIT=100
